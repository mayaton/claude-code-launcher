#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

print_usage() {
  cat <<EOF
Usage:
  cl [-- CLAUDE_ARGS...]

ghq 配下のリポジトリを fzf で選び、そのディレクトリで claude を起動する。

挙動:
  - herdr セッション内（\$HERDR_PANE_ID が定義済み）:
      リポ名の workspace が既に存在すればフォーカスし、無ければ新規作成して
      その初期ペイン内で claude を起動する。
  - Zellij セッション内（\$ZELLIJ が定義済み）:
      リポ名のタブを新規作成し、その cwd で claude を起動する。
  - それ以外:
      現在のシェルで cd してから claude に exec する。

依存:
  ghq, fzf, claude (Claude Code), herdr + jq / zellij (それぞれの環境で使う場合のみ)
  direnv (任意。インストールされていれば cd 先の .envrc を読み込んで claude を起動する)

Options:
  -h, --help  Show this help and exit

Arguments:
  -- 以降の引数は claude にそのまま渡す（herdr / 非マルチプレクサモード。Zellij モードは非対応）。

Environment:
  CL_NO_DIRENV  set to any non-empty value to disable direnv integration.
EOF
}

die() {
  echo "$1" >&2
  exit 1
}

require_cmd() {
  local cmd=$1 context=${2:-}
  if ! command -v "$cmd" >/dev/null 2>&1; then
    if [[ -n $context ]]; then
      die "Error: $context '$cmd' command not found"
    else
      die "Error: '$cmd' command not found"
    fi
  fi
}

should_use_direnv() {
  [[ -z ${CL_NO_DIRENV:-} ]] && command -v direnv >/dev/null 2>&1
}

build_claude_cmd() {
  local cmd arg quoted
  if should_use_direnv; then
    cmd="direnv exec . claude"
  else
    cmd="claude"
  fi
  for arg in "$@"; do
    printf -v quoted ' %q' "$arg"
    cmd+="$quoted"
  done
  printf '%s' "$cmd"
}

run_herdr() {
  require_cmd herdr "HERDR_PANE_ID is set but"
  require_cmd jq "HERDR_PANE_ID is set but"
  local workspace_id pane_id cmd
  workspace_id="$(herdr workspace list |
    jq -r --arg label "$tab_name" '.result.workspaces[] | select(.label==$label) | .workspace_id' |
    head -n1)"
  if [[ -n $workspace_id ]]; then
    herdr workspace focus "$workspace_id" >/dev/null
    return
  fi
  workspace_id="$(herdr workspace create --cwd "$repo_path" --label "$tab_name" --focus |
    jq -r '.result.workspace.workspace_id // .result.workspace_id // .result.workspace.id // empty')"
  if [[ -z $workspace_id ]]; then
    die "Error: failed to create herdr workspace"
  fi
  pane_id="$(herdr pane list --workspace "$workspace_id" |
    jq -r '.result.panes[0].pane_id // empty')"
  if [[ -z $pane_id ]]; then
    die "Error: failed to locate default pane in workspace $workspace_id"
  fi
  cmd="$(build_claude_cmd ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"})"
  herdr pane run "$pane_id" "$cmd" >/dev/null
}

run_zellij() {
  require_cmd zellij "ZELLIJ is set but"
  local cmd
  zellij action new-tab --name "$tab_name" --cwd "$repo_path"
  if should_use_direnv; then
    printf -v cmd 'cd %q && direnv exec . claude' "$repo_path"
  else
    printf -v cmd 'cd %q && claude' "$repo_path"
  fi
  zellij action write-chars "$cmd"
  zellij action write 13
}

run_plain() {
  require_cmd claude
  cd "$repo_path"
  if should_use_direnv; then
    exec direnv exec . claude ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
  else
    exec claude ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
  fi
}

CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
  case $1 in
  -h | --help)
    print_usage
    exit 0
    ;;
  --)
    shift
    CLAUDE_ARGS=("$@")
    break
    ;;
  *)
    echo "Unknown argument: $1" >&2
    print_usage >&2
    exit 1
    ;;
  esac
done

require_cmd ghq
require_cmd fzf

ghq_root="$(ghq root)"
repo="$(ghq list | fzf \
  --prompt='claude> ' \
  --height=80% \
  --reverse \
  --border \
  --preview="ls -la ${ghq_root}/{}" \
  --preview-window='right:50%:wrap')" || exit 0
repo_path="${ghq_root}/${repo}"
tab_name="${repo##*/}"

if [[ -n ${HERDR_PANE_ID:-} ]]; then
  run_herdr
elif [[ -n ${ZELLIJ:-} ]]; then
  run_zellij
else
  run_plain
fi
